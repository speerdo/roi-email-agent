# PrivateEmail (Namecheap) IMAP/SMTP for the monitored mailbox
EMAIL_IMAP_HOST=mail.privateemail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=mail.privateemail.com
EMAIL_SMTP_PORT=465
EMAIL_USER=hello@recycleoldtech.com
EMAIL_PASS=your_mailbox_password_here

# Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CLASSIFY_MODEL=gemini-2.5-flash

# Neon (Postgres) — pooled connection string, server-side only
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Discord bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_PUBLIC_KEY=your_discord_app_public_key_here
DISCORD_CHANNEL_ID=your_approval_channel_id_here

# Auth for the /api/poll cron endpoint
CRON_SECRET=generate_a_long_random_string_here

# === Deterministic pre-filters (run BEFORE any LLM call) ===

# 1. Recycling request — already handled by Make.com via Web3Forms.
#    Match subject prefix AND the Web3Forms sender (both required).
AUTOMATED_FORM_SUBJECTS=Recycling request from
AUTOMATED_FORM_FROM=notify@web3forms.com
AUTOMATED_FORM_BODY_MARKER=
AUTOMATED_FORM_MARK_READ=true

# 2. Waste Advantage newsletter -> mark read, skip.
NEWSLETTER_FROM=wasteadvantagemag.com
NEWSLETTER_SUBJECTS=
NEWSLETTER_MARK_READ=true

# 3. DMARC aggregate reports -> mark read, skip.
DMARC_SUBJECTS=Report domain:,Report Domain:
DMARC_FROM=
DMARC_MARK_READ=true