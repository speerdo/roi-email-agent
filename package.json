{
  "name": "roi-email-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "RecycleOldTech email triage agent (IMAP -> Gemini -> Discord approval -> SMTP)",
  "scripts": {
    "preflight": "tsx scripts/preflight.ts",
    "dev": "vercel dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@neondatabase/serverless": "^0.10.0",
    "discord-interactions": "^4.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "imapflow": "^1.0.189",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.16",
    "@vercel/node": "^5.8.17",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.0.0"
  }
